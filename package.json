{
  "name": "lacsef-website",
  "private": true,
  "scripts": {
    "start": "bun run build && bunx serve .",
    "dev": "bun run watch:css",
    "build": "bun run build:css && bun run build:articles && bun run build:thumbs",
    "build:css": "tailwindcss -i src/main.css -o css/styles.css --minify",
    "build:articles": "bun scripts/build-articles.mjs",
    "build:thumbs": "bun scripts/build-thumbnails.mjs",
    "watch:css": "tailwindcss -i src/main.css -o css/styles.css --watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.9",
    "@tailwindcss/typography": "^0.5.15",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "marked": "^14.1.3",
    "prettier": "^3.3.3",
    "serve": "^14.2.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.13"
  },
  "lint-staged": {
    "*.{html,js,json,md,mjs}": "prettier --write",
    "src/**/*.css": "prettier --write"
  }
}
